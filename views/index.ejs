<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recipie</title>
    <script src="./app.js" defer></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <script src="../js/index.js" defer></script>
    <script src="../js/auth.js" defer></script>
    <script src="../js/format.js" defer></script>
    <link rel="stylesheet" href="../style/scss/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" integrity="sha512-SnH5WK+bZxgPHs44uWIX+LLJAJ9/2PkPKZ5QiAj6Ta86w+fsb2TkcmfRyVX3pBnMFcV7oQPJkl9QevSCWr3W6A==" crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>
<body>
    <!-- Flash MessagesetUp Code -->
    <% if(successFlash) { %>
        <div class="alert alert-success alert-dismissible  show" role="alert">
            <strong>Holy guacamole!</strong><%= successFlash %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
              <span aria-hidden="true">&times;</span>
            </button>
          </div>
    <% }%>
    <!-- Nav Bar Code -->
    <nav>
        <div class="history">
            <a href=""><i class="fa-solid fa-clock-rotate-left"></i>History</a>
        </div>
        <div class="profile_pic">
            <img src="<%= modifiedImagePath %>" alt="Pic">
            <p><%= userData.username %></p>
        </div>
        <div class="logoutButton">
            <a href="/logout">logout</a>
        </div>
    </nav>

    <!-- <h1>Welcome! <%= userData.username %></h1> -->
    <div class="main">
        <div class="grabber">
            <img src="../images/uploads/default.jpg" alt="pic" class="userProfile">
        <textarea name="input" id="input" placeholder="Enter Your Recipie Prompt"></textarea>
        <button id="btn"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-move-right"><path d="M18 8L22 12L18 16"/><path d="M2 12H22"/></svg></button>
        </div>
    </div>
<div class="response">
    <div class="demoItem">
        <div class="cpyItem">Generate a recipie of tasty Chicken Biriyani In indian Style.</div>
        <div class="cpyItem b">Generate a recipie of dilisious Japanese Food also tell me the steps of cooking.</div>
        <div class="cpyItem">Generate a recipie of a Tea also mention all the ingrediants used over the process.</div>
    </div>
    <div id="result"></div>
</div>

    <!-- <h2>Search History</h2>
    <ul id="searchHistory">
        <% searchHistory.forEach((item, index) => { %>
            <div id="hist">
                <li id="history<%= index %>">
                    <%= item.query %> - <%= extractDate(item.timestamp) %>
                </li>
                <button class="copy-button" data-index="<%= index %>">Copy</button>
            </div>
        <% }); %>
    </ul>     -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

</body>
</html>

