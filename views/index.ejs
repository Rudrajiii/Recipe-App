<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recipie</title>
    <script src="./app.js" defer></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <script src="../js/index.js" defer></script>
    <script src="../js/auth.js" defer></script>
    <link rel="stylesheet" href="../style/scss/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" integrity="sha512-SnH5WK+bZxgPHs44uWIX+LLJAJ9/2PkPKZ5QiAj6Ta86w+fsb2TkcmfRyVX3pBnMFcV7oQPJkl9QevSCWr3W6A==" crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>
<body>
    <!-- Flash MessagesetUp Code -->
    <% if(successFlash) { %>
        <div class="alert alert-success alert-dismissible  show" role="alert">
            <strong>Holy guacamole!</strong><%= successFlash %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
              <span aria-hidden="true">&times;</span>
            </button>
          </div>
    <% }%>
    <!-- Nav Bar Code -->
    <nav>
        <div class="history">
            <a href=""><i class="fa-solid fa-clock-rotate-left"></i>History</a>
        </div>
        <div class="profile_pic">
            <img src="<%= modifiedImagePath %>" alt="Pic">
            <p><%= userData.username %></p>
        </div>
        <div class="logoutButton">
            <a href="/logout">logout</a>
        </div>
    </nav>

    <h1>Welcome! <%= userData.username %></h1>
    <div class="main">
        <h1>Recipie app..</h1>
        <textarea name="input" id="input"></textarea>
        <button id="btn">Generate</button>
    </div>
    
    <div id="result"></div>

    <h2>Search History</h2>
    <ul>
        <% searchHistory.forEach(item => { %>
            <li><%= item.query %> - <%= item.timestamp %></li>
        <% }); %>
    </ul>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

</body>
</html>

