<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recipie-App</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <script src="../js/auth.js" defer></script>
</head>
<body>
    <h1>Login Page</h1>
    <% if(errorFlash.length > 0) { %>
        <p style="color: red; font-size: 20px;"><%= errorFlash %></p>
    <% }%>
    <form id="reg-form" action="/login"  method="post">
        <label for="userName">Name:</label>
        <input name="username" type="text" autocomplete="off" id="username" placeholder="Username" />
        <label for="password">password:</label>
        <input name="password"  type="password" autocomplete="off" id="password" placeholder="Password" />
        <input class="btn btn-danger" type="submit" value="Submit Form" />
    </form>
    <a href="/">Not in Recipie.in? Create One</a>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>



