<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recipie-App</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="../style/scss/auth.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" integrity="sha512-SnH5WK+bZxgPHs44uWIX+LLJAJ9/2PkPKZ5QiAj6Ta86w+fsb2TkcmfRyVX3pBnMFcV7oQPJkl9QevSCWr3W6A==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <script src="../js/auth.js" defer></script>
</head>
<body>
    <!-- 2 sections one contain image one contain form details -->
    <div class="leftContainerPart">
        <img src="https://images.unsplash.com/photo-1511690656952-34342bb7c2f2?w=500&auto=format&fit=crop&q=60&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxzZWFyY2h8NHx8dmFyaXR5JTIwb2YlMjBmb29kJTIwaW1hZ2V8ZW58MHx8MHx8fDA%3D" alt="FoodImage">
    </div>
    <div class="rightContainerPart">
        <div class="formWrapper">
            <div id="socials">
                <a href="">
                    <i class="fa-brands fa-linkedin"></i>
                </a>
                <a href="">
                    <i class="fa-brands fa-github"></i>
                </a>
                <a href="">
                    <i class="fa-brands fa-x-twitter"></i>
                </a>
            </div>
            <div class="form">
                <form id="reg-form" action="/register"  method="post" enctype="multipart/form-data">
                    <div class="head">
                        <h3>Welcome to <span>Recipie.in</span></h3>
                        <h5>Create your account</h5>
                    </div>
                    <% if(itemNotFoundError) { %>
                        <p style="color: rgb(255, 0, 0); font-size: 20px;"><%= itemNotFoundError %></p>
                    <% }%>
                        <input name="username" type="text" autocomplete="off" id="username" placeholder="Username" />
                        <input name="email" type="email" autocomplete="off" id="email" placeholder="Email" />
                        <input name="password"  type="password" autocomplete="off" id="password" placeholder="Password" />
                        <input name="profilePic" type="file" id="profilePic" accept="image/*">
                        <input class="btn" type="submit" value="Submit Form" />
                </form>
            </div>
            <a id="veri" href="/verify" style="color: #0287FF;">Already in Recipie.in? Login</a>
        </div>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>

